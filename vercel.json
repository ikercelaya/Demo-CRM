{
  "version": 2,
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/chat",
      "destination": "/chat.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Demo-Mode",
          "value": "MOMA CRM demo without database"
        }
      ]
    }
  ]
}
